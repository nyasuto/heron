<?xml version="1.0"?>
<!--
  Compass Gait Walker template.
  Substituted by scripts/walk_compass.py via str.format(**asdict(params), ...).
  Frame: x = forward, y = lateral (hip joint axis), z = up.

  Root chain: world_base (fixed) -> virtual_x (prismatic x) -> virtual_z (prismatic z)
              -> virtual_pitch (revolute about y) -> hip. This restricts the walker
              to the x-z (sagittal) plane; the URDF must be loaded with fixed=True so
              that world_base anchors the chain.
-->
<robot name="compass_walker">

  <!-- Anchored to world; mass/inertia are nominal nonzero values (Genesis warns on zeros). -->
  <link name="world_base">
    <inertial>
      <mass value="1e-6"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>

  <link name="virtual_x_link">
    <inertial>
      <mass value="1e-6"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="virtual_x" type="prismatic">
    <parent link="world_base"/>
    <child link="virtual_x_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-100" upper="100" effort="0" velocity="100"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="virtual_z_link">
    <inertial>
      <mass value="1e-6"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="virtual_z" type="prismatic">
    <parent link="virtual_x_link"/>
    <child link="virtual_z_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-100" upper="100" effort="0" velocity="100"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <joint name="virtual_pitch" type="continuous">
    <parent link="virtual_z_link"/>
    <child link="hip"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- Hip: point mass; pose set by virtual_x/virtual_z/virtual_pitch -->
  <link name="hip">
    <visual>
      <geometry><sphere radius="0.04"/></geometry>
      <material name="hip_red"><color rgba="0.85 0.15 0.15 1.0"/></material>
    </visual>
    <inertial>
      <mass value="{hip_mass}"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Left leg (cylinder hanging below the hip; angle controlled by hip_left joint) -->
  <link name="left_leg">
    <visual>
      <geometry><cylinder radius="{leg_radius}" length="{leg_length}"/></geometry>
      <origin xyz="0 0 -{leg_length_half}" rpy="0 0 0"/>
      <material name="leg_blue"><color rgba="0.15 0.35 0.85 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="{leg_radius}" length="{leg_length}"/></geometry>
      <origin xyz="0 0 -{leg_length_half}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="{leg_mass}"/>
      <inertia ixx="{leg_inertia}" ixy="0" ixz="0" iyy="{leg_inertia}" iyz="0" izz="1e-5"/>
      <origin xyz="0 0 -{leg_length_half}" rpy="0 0 0"/>
    </inertial>
  </link>

  <link name="left_foot">
    <visual>
      <geometry><sphere radius="{foot_radius}"/></geometry>
      <material name="foot_dark"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="{foot_radius}"/></geometry>
    </collision>
    <inertial>
      <mass value="{foot_mass}"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="hip_left" type="continuous">
    <parent link="hip"/>
    <child link="left_leg"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <joint name="left_ankle" type="fixed">
    <parent link="left_leg"/>
    <child link="left_foot"/>
    <origin xyz="0 0 -{leg_length}" rpy="0 0 0"/>
  </joint>

  <!-- Right leg (mirror of left) -->
  <link name="right_leg">
    <visual>
      <geometry><cylinder radius="{leg_radius}" length="{leg_length}"/></geometry>
      <origin xyz="0 0 -{leg_length_half}" rpy="0 0 0"/>
      <material name="leg_green"><color rgba="0.15 0.85 0.35 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="{leg_radius}" length="{leg_length}"/></geometry>
      <origin xyz="0 0 -{leg_length_half}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="{leg_mass}"/>
      <inertia ixx="{leg_inertia}" ixy="0" ixz="0" iyy="{leg_inertia}" iyz="0" izz="1e-5"/>
      <origin xyz="0 0 -{leg_length_half}" rpy="0 0 0"/>
    </inertial>
  </link>

  <link name="right_foot">
    <visual>
      <geometry><sphere radius="{foot_radius}"/></geometry>
      <material name="foot_dark"/>
    </visual>
    <collision>
      <geometry><sphere radius="{foot_radius}"/></geometry>
    </collision>
    <inertial>
      <mass value="{foot_mass}"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="hip_right" type="continuous">
    <parent link="hip"/>
    <child link="right_leg"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <joint name="right_ankle" type="fixed">
    <parent link="right_leg"/>
    <child link="right_foot"/>
    <origin xyz="0 0 -{leg_length}" rpy="0 0 0"/>
  </joint>

</robot>
